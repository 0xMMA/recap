<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Recap.Desktop.ViewModels"
        xmlns:conv="using:Recap.Desktop.Converters"
        xmlns:controls="using:Recap.Desktop.Controls"
        x:Class="Recap.Desktop.Views.MainWindow"
        Title="Recap" Width="900" Height="600"
        MinWidth="640" MinHeight="400"
        Icon="avares://Recap/Assets/icon.ico"
        x:DataType="vm:MainWindowViewModel">

    <Window.Styles>
        <Style Selector="Border.toolbar Button">
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="MinHeight" Value="52" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="#383838" />
            <Setter Property="Foreground" Value="#DDD" />
        </Style>
    </Window.Styles>

    <Window.Resources>
        <conv:DurationConverter x:Key="DurationConverter" />
    </Window.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Classes="toolbar" Background="#2D2D2D" Padding="8,6"
                CornerRadius="0" BorderThickness="0,0,0,1" BorderBrush="#444">
            <StackPanel Orientation="Horizontal" Spacing="2">
                <!-- Record -->
                <Button Focusable="False" ToolTip.Tip="Start or stop recording (R)"
                        Command="{Binding ToggleRecordingCommand}">
                    <Grid>
                        <TextBlock Text="R" FontSize="9" Foreground="#555"
                                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0" />
                        <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#x23FA;" FontSize="18" HorizontalAlignment="Center"
                                       Foreground="{Binding RecordingState, Converter={x:Static conv:RecordingStateConverters.Foreground}}" />
                            <TextBlock Text="Record" FontSize="9" HorizontalAlignment="Center" Foreground="#CCC" />
                        </StackPanel>
                    </Grid>
                </Button>

                <Border Width="1" Background="#555" Margin="6,6" />

                <!-- Play -->
                <Button Focusable="False" ToolTip.Tip="Play selected segment (Enter)"
                        Command="{Binding PlaySelectedCommand}">
                    <Grid>
                        <TextBlock Text="&#x23CE;" FontSize="9" Foreground="#555"
                                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0" />
                        <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#x25B6;" FontSize="18" HorizontalAlignment="Center" />
                            <TextBlock Text="Play" FontSize="9" HorizontalAlignment="Center" Foreground="#CCC" />
                        </StackPanel>
                    </Grid>
                </Button>
                <!-- Play All -->
                <Button Focusable="False" ToolTip.Tip="Play all segments spliced (Shift+Enter)"
                        Command="{Binding PlayAllCommand}">
                    <Grid>
                        <TextBlock Text="&#x21E7;&#x23CE;" FontSize="9" Foreground="#555"
                                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0" />
                        <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#x23E9;" FontSize="18" HorizontalAlignment="Center" />
                            <TextBlock Text="Play All" FontSize="9" HorizontalAlignment="Center" Foreground="#CCC" />
                        </StackPanel>
                    </Grid>
                </Button>
                <!-- Pause -->
                <Button Focusable="False" ToolTip.Tip="Pause or resume playback (Space)"
                        Command="{Binding TogglePauseCommand}">
                    <Grid>
                        <TextBlock Text="&#x2423;" FontSize="9" Foreground="#555"
                                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0" />
                        <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#x23F8;" FontSize="18" HorizontalAlignment="Center" />
                            <TextBlock Text="Pause" FontSize="9" HorizontalAlignment="Center" Foreground="#CCC" />
                        </StackPanel>
                    </Grid>
                </Button>

                <Border Width="1" Background="#555" Margin="6,6" />

                <!-- Trim -->
                <Button Focusable="False" ToolTip.Tip="Trim selected segment (T)"
                        Command="{Binding EnterTrimModeCommand}">
                    <Grid>
                        <TextBlock Text="T" FontSize="9" Foreground="#555"
                                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0" />
                        <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#x2702;" FontSize="18" HorizontalAlignment="Center" />
                            <TextBlock Text="Trim" FontSize="9" HorizontalAlignment="Center" Foreground="#CCC" />
                        </StackPanel>
                    </Grid>
                </Button>
                <!-- Auto-Trim -->
                <Button Focusable="False" ToolTip.Tip="Auto-remove silence from selection (A)"
                        Command="{Binding AutoTrimCommand}">
                    <Grid>
                        <TextBlock Text="A" FontSize="9" Foreground="#555"
                                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0" />
                        <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#x26A1;" FontSize="18" HorizontalAlignment="Center" />
                            <TextBlock Text="Auto Trim" FontSize="9" HorizontalAlignment="Center" Foreground="#CCC" />
                        </StackPanel>
                    </Grid>
                </Button>

                <Border Width="1" Background="#555" Margin="6,6" />

                <!-- Transcribe -->
                <Button Focusable="False" ToolTip.Tip="Transcribe selected segments (X)"
                        Command="{Binding TranscribeCommand}">
                    <Grid>
                        <TextBlock Text="X" FontSize="9" Foreground="#555"
                                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0" />
                        <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Tx" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Text="Transcribe" FontSize="9" HorizontalAlignment="Center" Foreground="#CCC" />
                        </StackPanel>
                    </Grid>
                </Button>
                <!-- Transcribe All -->
                <Button Focusable="False" ToolTip.Tip="Transcribe all segments combined (Shift+X)"
                        Command="{Binding TranscribeAllCommand}">
                    <Grid>
                        <TextBlock Text="&#x21E7;X" FontSize="9" Foreground="#555"
                                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0" />
                        <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="TX" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Text="TX All" FontSize="9" HorizontalAlignment="Center" Foreground="#CCC" />
                        </StackPanel>
                    </Grid>
                </Button>
                <!-- Language -->
                <Button Focusable="False" ToolTip.Tip="Cycle transcription language (L)"
                        Command="{Binding CycleLanguageCommand}">
                    <Grid>
                        <TextBlock Text="L" FontSize="9" Foreground="#555"
                                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0" />
                        <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ActiveLanguage}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Text="Lang" FontSize="9" HorizontalAlignment="Center" Foreground="#CCC" />
                        </StackPanel>
                    </Grid>
                </Button>

                <Border Width="1" Background="#555" Margin="6,6" />

                <!-- Save -->
                <Button x:Name="SaveButton" Focusable="False" ToolTip.Tip="Save audio to file (S)">
                    <Grid>
                        <TextBlock Text="S" FontSize="9" Foreground="#555"
                                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0" />
                        <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#x2B07;" FontSize="18" HorizontalAlignment="Center" />
                            <TextBlock Text="Save" FontSize="9" HorizontalAlignment="Center" Foreground="#CCC" />
                        </StackPanel>
                    </Grid>
                </Button>
                <!-- Open Folder -->
                <Button Focusable="False" ToolTip.Tip="Open segment folder in Explorer (F)"
                        Command="{Binding OpenInExplorerCommand}">
                    <Grid>
                        <TextBlock Text="F" FontSize="9" Foreground="#555"
                                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0" />
                        <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#x25B8;" FontSize="18" HorizontalAlignment="Center" />
                            <TextBlock Text="Folder" FontSize="9" HorizontalAlignment="Center" Foreground="#CCC" />
                        </StackPanel>
                    </Grid>
                </Button>
                <!-- New -->
                <Button Focusable="False" ToolTip.Tip="Start new recording session (N)"
                        Command="{Binding NewSessionCommand}">
                    <Grid>
                        <TextBlock Text="N" FontSize="9" Foreground="#555"
                                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0" />
                        <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="+" FontSize="18" HorizontalAlignment="Center" />
                            <TextBlock Text="New" FontSize="9" HorizontalAlignment="Center" Foreground="#CCC" />
                        </StackPanel>
                    </Grid>
                </Button>
                <!-- Settings -->
                <Button x:Name="SettingsButton" Focusable="False" ToolTip.Tip="Open settings (Ctrl+,)">
                    <Grid>
                        <TextBlock Text="&#x2318;," FontSize="9" Foreground="#555"
                                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0" />
                        <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#x2699;" FontSize="18" HorizontalAlignment="Center" />
                            <TextBlock Text="Settings" FontSize="9" HorizontalAlignment="Center" Foreground="#CCC" />
                        </StackPanel>
                    </Grid>
                </Button>
            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="#1E1E1E" Padding="8,4">
            <DockPanel>
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <TextBlock x:Name="VersionText" Foreground="#666" FontSize="10" VerticalAlignment="Center" />
                    <Button Content="GitHub" Focusable="False" FontSize="10" Padding="4,2"
                            Background="Transparent" Foreground="#888" Cursor="Hand"
                            Click="GitHub_Click" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <TextBlock FontSize="12"
                               Foreground="{Binding RecordingState, Converter={x:Static conv:RecordingStateConverters.Foreground}}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0}">
                                <Binding Path="RecordingState" Converter="{x:Static conv:RecordingStateConverters.StatusLabel}" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Text="{Binding ActiveLanguage, StringFormat='Lang: {0}'}" FontSize="12" Foreground="#AAA" />
                    <TextBlock Text="{Binding SegmentCount, StringFormat='Segments: {0}'}" FontSize="12" Foreground="#AAA" />
                    <TextBlock Text="{Binding TotalDuration, StringFormat='Duration: {0}'}" FontSize="12" Foreground="#AAA" />
                    <TextBlock FontSize="12">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="API: {0}">
                                <Binding Path="HasApiKey" Converter="{x:Static conv:RecordingStateConverters.ApiStatus}" />
                            </MultiBinding>
                        </TextBlock.Text>
                        <TextBlock.Foreground>
                            <Binding Path="HasApiKey" Converter="{x:Static conv:RecordingStateConverters.ApiColor}" />
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#CCC" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Segment List (Left) -->
        <Border DockPanel.Dock="Left" Width="200" Background="#252525" BorderBrush="#333" BorderThickness="0,0,1,0">
            <ListBox x:Name="SegmentList"
                     ItemsSource="{Binding Segments}"
                     Background="Transparent"
                     SelectionMode="Single"
                     SelectionChanged="SegmentList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:SegmentViewModel">
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,2">
                            <Ellipse Width="8" Height="8" Fill="#00CC66"
                                     IsVisible="{Binding IsPlaying}"
                                     VerticalAlignment="Center" Margin="0,0,0,0" />
                            <TextBlock Text="{Binding DisplayIndex, StringFormat='{}{0:D2}'}"
                                       FontFamily="Consolas,Courier New,monospace"
                                       FontSize="13" Foreground="#888" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Duration}"
                                       FontFamily="Consolas,Courier New,monospace"
                                       FontSize="13" Foreground="#CCC" VerticalAlignment="Center" />
                            <TextBlock Text="!"
                                       IsVisible="{Binding !HasFile}"
                                       Foreground="#E44" FontWeight="Bold" FontSize="13"
                                       VerticalAlignment="Center"
                                       ToolTip.Tip="File missing" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Center Content -->
        <Border Background="#1A1A1A">
            <DockPanel>
                <!-- Waveform -->
                <controls:WaveformControl x:Name="Waveform"
                                          DockPanel.Dock="Top"
                                          Height="120"
                                          Peaks="{Binding WaveformPeaks}"
                                          IsRecording="{Binding RecordingState, Converter={x:Static conv:RecordingStateConverters.IsRecording}}"
                                          IsTrimMode="{Binding IsTrimMode}"
                                          TrimLeft="{Binding TrimLeft, Mode=TwoWay}"
                                          TrimRight="{Binding TrimRight, Mode=TwoWay}"
                                          PlaybackPosition="{Binding PlaybackPosition}"
                                          SelectionStart="{Binding SelectionStart, Mode=TwoWay}"
                                          SelectionEnd="{Binding SelectionEnd, Mode=TwoWay}" />

                <!-- Transcript display -->
                <ScrollViewer Margin="16"
                              IsVisible="{Binding TranscriptText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding TranscriptText}"
                               TextWrapping="Wrap" FontSize="14" Foreground="#DDD"
                               Padding="8" />
                </ScrollViewer>
            </DockPanel>
        </Border>
    </DockPanel>
</Window>
